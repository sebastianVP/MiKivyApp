<MiInterfaz>:

    orientation: "vertical"
    padding: 20
    spacing: 20

    Image:
        id: mi_imagen
        source: "imagen1.png"

    Button:
        text: "Cambiar Imagen"
        font_size: "20sp"
        on_press: root.cambiar_imagen()


    Label:
        text: "Alexander Valdez-14 - Primeras pruebas"
        font_size: "24sp"
        halign: "center"